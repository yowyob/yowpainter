flowchart TB
    subgraph Acteurs["Acteurs humains"]
        Artist[Artiste]
        Buyer[Acheteur]
        Admin[Administrateur]
    end

    subgraph Client["Couche présentation"]
        FE[Frontend Next.js<br/>Port 3000]
    end

    YOW["YowPainter Backend<br/>Port 8090<br/>API REST + WebSocket"]

