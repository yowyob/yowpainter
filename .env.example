# Copier vers .env.local et adapter (ne pas committer .env.local)

# Kernel local (doit tourner sur 8080)
KSM_KERNEL_BASE_URL=http://localhost:8080

# Option A — client dedie YowPainter (apres bootstrap-kernel-client.ps1)
#KSM_KERNEL_CLIENT_ID=yowpainter-backend
# Executer scripts/bootstrap-kernel-client.ps1 une fois (kernel local)
#KSM_KERNEL_API_KEY=yowpainter-local-dev-secret-2026

# Option B — dev rapide sans bootstrap (client kernel par defaut, tous services)
KSM_KERNEL_CLIENT_ID=dev-platform-backend
KSM_KERNEL_API_KEY=dev-api-key

KSM_KERNEL_TENANT_ID=11111111-1111-1111-1111-111111111111
KSM_KERNEL_JWK_SET_URI=http://localhost:8080/.well-known/jwks.json
KSM_KERNEL_DEFAULT_PLAN_CODE=COMMERCE
KSM_KERNEL_DEFAULT_CURRENCY=XAF
KSM_KERNEL_SIGNUP_PLATFORM_ORG_CODE=yow-painter

# true = activation artiste automatique au login ; false = validation admin (recommande prod)
KSM_KERNEL_AUTO_PROVISION_ARTISTS=false

# Backend YowPainter (evite conflit avec kernel sur 8080)
PORT=8090

# PostgreSQL Render (external URL) — ou DB locale
# SPRING_DATASOURCE_URL=jdbc:postgresql://...
# DB_USER=...
# DB_PASS=...

# Frontend (CORS + emails)
FRONTEND_URL=http://localhost:3000

# Admin kernel local (inscription artiste : role ORGANIZATION_ADMIN)
KSM_KERNEL_BOOTSTRAP_ADMIN_USERNAME=platform-admin
KSM_KERNEL_BOOTSTRAP_ADMIN_PASSWORD=PlatformAdmin!123
# Optionnel en prod : client dedie pour login platform-admin (sinon reutilise KSM_KERNEL_CLIENT_ID)
#KSM_KERNEL_BOOTSTRAP_CLIENT_ID=prod-platform-backend
#KSM_KERNEL_BOOTSTRAP_API_KEY=
